# DO NOT commit a real .env file. Copy this to .env.local for development
# or to .env in the project root for docker-compose.

# ---- Runtime ----
NODE_ENV=development
PORT=3000

# ---- Database ----
# Path to the SQLite file. In Docker, mount /data as a volume.
DATABASE_PATH=./.data/lamutuelleseniors.db

# ---- Lead delivery (FR-006) ----
# mock = no external call (default while the real platform spec is pending)
# http = call the configured external endpoint (requires URL and auth)
LEAD_DELIVERY_MODE=mock
LEAD_DELIVERY_URL=
LEAD_DELIVERY_AUTH=

# ---- Operator email notifications (FR-013) ----
# Set MAIL_NOTIFY=false to disable email sending entirely.
MAIL_NOTIFY=false
GMAIL_USER=
GMAIL_PASS=
MAIL_TO=
MAIL_FROM=

# ---- Analytics (Plausible — privacy-friendly, no cookies) (FR-026) ----
# Domain MUST match what's configured in your Plausible dashboard.
PLAUSIBLE_DOMAIN=www.la-mutuelle-seniors.fr
PLAUSIBLE_HOST=https://plausible.io

# ---- Anti-abuse (FR-014) ----
RATE_LIMIT_SUBMISSIONS_PER_HOUR=10
# Optional Cloudflare Turnstile (leave empty to disable)
ANTIBOT_TURNSTILE_SITEKEY=
ANTIBOT_TURNSTILE_SECRET=
# Random long token required to call /api/lead/retry (e.g. via host cron).
# Generate with: openssl rand -hex 32
RETRY_CRON_TOKEN=change-me-to-a-long-random-string

# ---- Logging ----
# pino levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ---- Search engine verification (optional) ----
# Paste the verification token from Search Console "HTML tag" method.
# These are passed as Docker BUILD ARGS so static metadata embeds them
# at build time — set them BEFORE `docker compose up -d --build`.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# ---- Brand & legal identity (provided by métier in pre-deploy) ----
# Interpolated into legal pages and the footer.
SITE_NAME=La Mutuelle Seniors
SITE_LEGAL_ENTITY=
SITE_LEGAL_ADDRESS=
SITE_EMAIL=
SITE_DPO_NAME=
SITE_DPO_EMAIL=

# ---- Backup retention (optional) ----
# Used by scripts/backup-db.sh
BACKUP_RETENTION_DAYS=30
